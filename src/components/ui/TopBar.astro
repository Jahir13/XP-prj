---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header
  class="sticky top-0 z-30 flex items-center justify-between px-8 py-4 bg-zinc-950/60 backdrop-blur-xl border-b border-zinc-800/50"
>
  <div class="flex items-center gap-4">
    <div>
      <h1 class="text-lg font-semibold text-zinc-100">{title}</h1>
      {subtitle && <p class="text-xs text-zinc-500 font-mono mt-0.5">{subtitle}</p>}
    </div>
  </div>

  <div class="flex items-center gap-3">
    <!-- Client Mode Toggle -->
    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-zinc-800/50 border border-zinc-700/50">
      <span class="text-xs text-zinc-500 font-medium">Client Mode</span>
      <button
        id="client-mode-toggle"
        class="relative w-8 h-[18px] rounded-full bg-zinc-700 transition-colors duration-200 cursor-pointer"
        role="switch"
        aria-checked="false"
        aria-label="Toggle Client Mode"
      >
        <span
          class="absolute top-[2px] left-[2px] w-[14px] h-[14px] rounded-full bg-zinc-400 transition-transform duration-200"
        ></span>
      </button>
    </div>

    <!-- Keyboard Shortcut Hint -->
    <button
      class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-zinc-800/30 border border-zinc-800 text-zinc-500 hover:text-zinc-400 hover:border-zinc-700 transition-all text-xs cursor-pointer"
      title="Command Palette (Ctrl+K)"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg
      >
      <kbd class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-zinc-800 border border-zinc-700">Ctrl+K</kbd>
    </button>
  </div>
</header>
