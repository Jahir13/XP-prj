---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import StoreInitializer from '../components/ui/StoreInitializer';
import PairTracker from '../components/pair/PairTracker';

interface Props {
  title: string;
  subtitle?: string;
  currentPath: string;
  projectId?: string;
}

const { title, subtitle = 'XP-Flow', currentPath, projectId } = Astro.props;

const stories = await getCollection('stories');
const logs = await getCollection('logs');
const iterations = await getCollection('iterations');

const staticStories = stories.map((s) => ({
  id: s.id,
  title: s.data.title,
  businessValue: s.data.businessValue,
  risk: s.data.risk,
  points: s.data.points,
  status: s.data.status,
  iteration: s.data.iteration,
  assignedPair: s.data.assignedPair,
  isTDD: s.data.isTDD,
  acceptanceCriteria: s.data.acceptanceCriteria,
  createdBy: s.data.createdBy,
  estimatedBy: s.data.estimatedBy,
}));

const staticLogs = logs.map((l) => ({
  id: l.id,
  title: l.data.title,
  type: l.data.type,
  date: l.data.date ? new Date(l.data.date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0],
  status: l.data.status,
  relatedStory: l.data.relatedStory,
  participants: l.data.participants,
  descripcion: l.data.descripcion,
  prioridad: l.data.prioridad,
  historiaId: l.data.historiaId,
  estado: l.data.estado,
  responsableId: l.data.responsableId,
  githubRepo: l.data.githubRepo,
  githubFiles: l.data.githubFiles,
  githubCommit: l.data.githubCommit,
  codeSnippet: l.data.codeSnippet,
}));

const staticIterations = iterations.map((i) => ({
  id: i.id,
  projectId: i.data.projectId || '1',
  name: i.data.name,
  number: i.data.number,
  startDate: i.data.startDate.toISOString(),
  endDate: i.data.endDate.toISOString(),
  velocity: i.data.velocity,
  capacity: i.data.capacity,
  status: i.data.status,
}));

const pPrefix = projectId ? `/projects/${projectId}` : '';
const isActive = (path: string) => currentPath.startsWith(path);

const navGroups = [
  {
    label: 'Equipo',
    items: [{ href: `${pPrefix}/team`, label: 'Equipo', icon: 'users' }],
  },
  {
    label: 'Planeación',
    items: [
      { href: `${pPrefix || '/dashboard'}`, label: 'Panel de Control', icon: 'grid' },
      { href: `${pPrefix}/iterations`, label: 'Iteraciones', icon: 'layout' },
      { href: `${pPrefix}/standup`, label: 'Standup Diaria', icon: 'clock' },
      { href: `${pPrefix}/stories`, label: 'Historias', icon: 'file-text' },
    ],
  },
  {
    label: 'Diseño',
    items: [
      { href: '/design/architecture', label: 'Arquitectura escogida para nuestro proyecto', icon: 'file-text' },
      { href: '/design/lowfidelity', label: 'Low Fidelity', icon: 'file-text' },
    ],
  },
  {
    label: 'Desarrollo',
    items: [
      { href: `${pPrefix}/pairs`, label: 'Programación en Pareja', icon: 'users' },
      { href: `${pPrefix}/tdd`, label: 'Pruebas (TDD)', icon: 'check-square' },
      { href: `${pPrefix}/refactors`, label: 'Refactorización', icon: 'refresh' },
    ],
  },
  {
    label: 'Testing',
    items: [
      { href: '/tests?tab=plan', label: 'Plan de pruebas', icon: 'check-square' },
      { href: '/tests?tab=e2e', label: 'Pruebas funcionales y de integración', icon: 'check-square' },
    ],
  },
  {
    label: 'Calidad',
    items: [
      { href: `${pPrefix}/ci`, label: 'CI/CD', icon: 'activity' },
      { href: `${pPrefix}/compliance`, label: 'Cumplimiento XP', icon: 'shield-check' },
      { href: '/compliance/feedback', label: 'Feedback', icon: 'message' },
    ],
  },
];

const iconPaths: Record<string, string> = {
  grid: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z',
  'file-text': 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
  layout: 'M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zM3 9h18M9 21V9',
  activity: 'M22 12h-4l-3 9L9 3l-3 9H2',
  clock: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  users:
    'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
  'check-square': 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  refresh:
    'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  message:
    'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  'shield-check': 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10zM9 12l2 2 4-4',
};
---

<!doctype html>
<html lang="es-419">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="XP-Flow — Gestión de proyectos bajo Programación Extrema (XP)" />
    <title>{title} — XP-Flow</title>
    <meta property="og:title" content={`${title} — XP-Flow`} />
    <meta property="og:description" content="XP-Flow — Gestión de proyectos bajo Programación Extrema (XP)" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} — XP-Flow`} />
    <meta name="twitter:description" content="XP-Flow — Gestión de proyectos bajo Programación Extrema (XP)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      html {
        background-color: #09090b;
      }
    </style>
  </head>
  <body class="noise-bg min-h-screen antialiased">
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <StoreInitializer
      client:load
      staticStories={staticStories}
      staticLogs={staticLogs}
      staticIterations={staticIterations}
    />

    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <nav
        class="fixed left-0 top-0 h-screen w-56 bg-zinc-950/80 backdrop-blur-xl border-r border-zinc-800/50 flex flex-col z-40 overflow-y-auto"
      >
        <!-- Logo -->
        <a href={pPrefix || '/dashboard'} class="flex items-center gap-2.5 px-4 py-5 border-b border-zinc-800/50 group">
          <div
            class="w-8 h-8 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center group-hover:bg-indigo-500/20 group-hover:border-indigo-500/40 transition-all"
          >
            <span class="text-indigo-400 font-bold text-sm font-mono">XP</span>
          </div>
          <span class="text-sm font-semibold text-zinc-200">Flow</span>
        </a>

        <!-- Nav Groups -->
        <div class="flex-1 px-3 py-4 space-y-5">
          {
            navGroups.map((group) => (
              <div>
                <span class="text-[10px] font-semibold uppercase tracking-widest text-zinc-600 px-2 mb-2 block">
                  {group.label}
                </span>
                <div class="space-y-0.5">
                  {group.items.map((item) => {
                    const active = item.href ? isActive(item.href) : false;
                    return item.href ? (
                      <a
                        href={item.href}
                        class:list={[
                          'flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-xs font-medium transition-all duration-200',
                          active
                            ? 'bg-indigo-500/10 text-indigo-400 border border-indigo-500/20'
                            : 'text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800/50 border border-transparent',
                        ]}
                        title={item.label}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="15"
                          height="15"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d={iconPaths[item.icon]} />
                        </svg>
                        {item.label}
                      </a>
                    ) : (
                      <div
                        class:list={[
                          'flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-xs font-medium transition-all duration-200 select-none text-zinc-500/80 border border-transparent',
                        ]}
                        title={item.label}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="15"
                          height="15"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d={iconPaths[item.icon]} />
                        </svg>
                        <span class="truncate">{item.label}</span>
                      </div>
                    );
                  })}
                </div>
              </div>
            ))
          }
        </div>

        <!-- Bottom -->
        <div class="px-3 py-4 border-t border-zinc-800/50 space-y-1">
          <!-- User Profile Widget -->
          <div
            id="user-profile-widget"
            class="px-2.5 py-2 mb-2 rounded-lg bg-zinc-900/50 border border-zinc-800/60 flex items-center gap-3 hidden"
          >
            <div
              id="user-avatar"
              class="w-8 h-8 rounded-full bg-indigo-600/20 border border-indigo-500/30 flex items-center justify-center text-xs font-bold text-indigo-400"
            >
              --
            </div>
            <div class="min-w-0 flex-1">
              <div id="user-name" class="text-xs font-semibold text-zinc-200 truncate">Invitado</div>
              <div id="user-role" class="text-[10px] text-zinc-500 truncate font-mono">Rol</div>
            </div>
          </div>

          <a
            href="/settings"
            class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-xs font-medium text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800/50 transition-all border border-transparent"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
              ></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            Configuración
          </a>
          <button
            id="logout-btn"
            class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-xs font-medium text-zinc-500 hover:text-rose-400 hover:bg-rose-500/10 transition-all border border-transparent"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"
              ></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg
            >
            Cerrar Sesión
          </button>
        </div>
      </nav>

      <!-- Main -->
      <main id="main-content" class="flex-1 ml-56" role="main">
        <!-- Top Bar -->
        <header
          class="sticky top-0 z-30 flex items-center justify-between px-8 py-4 bg-zinc-950/60 backdrop-blur-xl border-b border-zinc-800/50"
        >
          <div>
            <h1 class="text-lg font-semibold text-zinc-100">{title}</h1>
            {subtitle && <p class="text-xs text-zinc-500 font-mono mt-0.5">{subtitle}</p>}
          </div>
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-zinc-800/50 border border-zinc-700/50">
              <span class="text-xs text-zinc-500 font-medium">Modo Cliente</span>
              <button
                id="client-mode-toggle"
                class="relative w-8 h-[18px] rounded-full bg-zinc-700 transition-colors duration-200 cursor-pointer"
                role="switch"
                aria-checked="false"
                aria-label="Cambiar Modo Cliente"
              >
                <span
                  class="absolute top-[2px] left-[2px] w-[14px] h-[14px] rounded-full bg-zinc-400 transition-transform duration-200"
                ></span>
              </button>
            </div>
            <button
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-zinc-800/30 border border-zinc-800 text-zinc-500 hover:text-zinc-400 hover:border-zinc-700 transition-all text-xs cursor-pointer"
              title="Paleta de Comandos (Ctrl+K)"
              aria-label="Buscar (Ctrl+K)"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg
              >
              <kbd class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-zinc-800 border border-zinc-700">Ctrl+K</kbd>
            </button>
          </div>
        </header>

        <!-- Page Content -->
        <div class="px-8 py-6">
          <slot />
        </div>
      </main>
    </div>

    <script>
      import { $isClientMode, toggleClientMode } from '../store/ui';
      import { $currentUser, setCurrentUser } from '../store/auth';

      const toggle = document.getElementById('client-mode-toggle');
      const knob = toggle?.querySelector('span');
      if (toggle && knob) {
        $isClientMode.subscribe((value) => {
          toggle.setAttribute('aria-checked', String(value));
          if (value) {
            toggle.classList.remove('bg-zinc-700');
            toggle.classList.add('bg-indigo-600');
            knob.classList.remove('left-[2px]');
            knob.classList.add('translate-x-[14px]', 'bg-white');
            knob.classList.remove('bg-zinc-400');
          } else {
            toggle.classList.remove('bg-indigo-600');
            toggle.classList.add('bg-zinc-700');
            knob.classList.remove('translate-x-[14px]', 'bg-white');
            knob.classList.add('left-[2px]', 'bg-zinc-400');
          }
        });
        toggle.addEventListener('click', () => toggleClientMode());
      }

      // User Profile Widget reactivity
      const userWidget = document.getElementById('user-profile-widget');
      const userAvatar = document.getElementById('user-avatar');
      const userName = document.getElementById('user-name');
      const userRole = document.getElementById('user-role');

      if (userWidget && userAvatar && userName && userRole) {
        $currentUser.subscribe((user) => {
          if (user) {
            userWidget.classList.remove('hidden');
            userName.textContent = user.name;
            userRole.textContent = user.xpRole;
            userAvatar.textContent = user.avatarInitials;
          } else {
            userWidget.classList.add('hidden');
          }
        });
      }

      const logoutBtn = document.getElementById('logout-btn');
      logoutBtn?.addEventListener('click', () => {
        localStorage.removeItem('xp-auth-admin');
        setCurrentUser(null);
        window.location.href = '/login';
      });
    </script>

    <PairTracker client:idle />
  </body>
</html>
