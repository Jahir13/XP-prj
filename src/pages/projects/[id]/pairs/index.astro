---
import AppLayout from '../../../../layouts/AppLayout.astro';
const { id } = Astro.params;
---

<AppLayout title="Pair Programming" subtitle={`Project ${id}`} currentPath={`/projects/${id}/pairs`} projectId={id}>
  <div class="max-w-4xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-sm font-semibold text-zinc-300">Pair Sessions</h2>
      <button
        id="start-pair-btn"
        class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold transition-all cursor-pointer"
        >+ Start Session</button
      >
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2">
        <div id="pair-history" class="space-y-2">
          <div class="text-center py-16 text-zinc-500 text-sm">Loading pair history...</div>
        </div>
      </div>
      <div>
        <!-- Rotation Suggestions -->
        <div class="rounded-xl bg-zinc-900/60 border border-zinc-800 p-4 mb-4">
          <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Rotation Suggestions</h3>
          <div id="rotation-suggestions" class="space-y-2">
            <div class="text-xs text-zinc-600">Loading suggestions...</div>
          </div>
        </div>

        <!-- Stats -->
        <div class="rounded-xl bg-zinc-900/60 border border-zinc-800 p-4">
          <h3 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Pairing Stats</h3>
          <div id="pair-stats" class="space-y-2">
            <div class="text-xs text-zinc-600">Loading...</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { pairsApi } from '../../../../api/pairsApi';

    const projectId = '{id}';
    const historyEl = document.getElementById('pair-history');
    const suggestionsEl = document.getElementById('rotation-suggestions');
    const statsEl = document.getElementById('pair-stats');

    async function load() {
      try {
        const [sessions, suggestions, history] = await Promise.all([
          pairsApi.list(projectId),
          pairsApi.rotationSuggestions(projectId),
          pairsApi.history(projectId),
        ]);

        if (sessions.length === 0 || history.length === 0) {
          historyEl!.innerHTML =
            '<div class="flex flex-col items-center py-16 rounded-xl border border-dashed border-zinc-800"><span class="text-3xl mb-3">👥</span><h3 class="text-sm font-semibold text-zinc-400">No pair sessions</h3><p class="text-xs text-zinc-500 mt-1">Start your first pair programming session</p></div>';
        } else {
          historyEl!.innerHTML = [...history]
            .reverse()
            .slice(0, 20)
            .map(
              (s) => `
            <a href="/projects/${projectId}/pairs/${s.id}" class="flex items-center justify-between p-3 rounded-lg bg-zinc-900/40 border border-zinc-800 hover:border-zinc-700 transition-all group">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-violet-500/10 flex items-center justify-center text-xs">👥</div>
                <div>
                  <div class="text-sm font-medium text-zinc-200">${s.driver} & ${s.navigator}</div>
                  <div class="text-[10px] text-zinc-500 font-mono">${s.durationMinutes}m · ${new Date(s.startTime).toLocaleDateString()}</div>
                </div>
              </div>
              <span class="text-[10px] px-2 py-0.5 rounded-full ${s.status === 'Active' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-zinc-800 text-zinc-500'}">${s.status}</span>
            </a>
          `,
            )
            .join('');
        }

        if (suggestions.length > 0) {
          suggestionsEl!.innerHTML = suggestions
            .map(
              (s) => `
            <div class="flex items-center justify-between p-2 rounded-lg bg-zinc-800/30">
              <span class="text-xs text-zinc-300">${s.pair[0]} ↔ ${s.pair[1]}</span>
              <span class="text-[10px] text-zinc-500 font-mono">${s.reason}</span>
            </div>
          `,
            )
            .join('');
        } else {
          suggestionsEl!.innerHTML = '<div class="text-xs text-zinc-600">Not enough history for suggestions</div>';
        }

        statsEl!.innerHTML = `
          <div class="flex justify-between text-xs"><span class="text-zinc-500">Total sessions</span><span class="text-zinc-300 font-mono">${history.length}</span></div>
          <div class="flex justify-between text-xs"><span class="text-zinc-500">Avg duration</span><span class="text-zinc-300 font-mono">${history.length > 0 ? Math.round(history.reduce((a: number, s: any) => a + s.durationMinutes, 0) / history.length) : 0}m</span></div>
          <div class="flex justify-between text-xs"><span class="text-zinc-500">Unique pairs</span><span class="text-zinc-300 font-mono">${new Set(history.flatMap((s: any) => [s.driver, s.navigator])).size}</span></div>
        `;
      } catch {
        historyEl!.innerHTML = '<div class="text-center py-16 text-rose-400 text-sm">Failed to load</div>';
      }
    }
    load();

    document.getElementById('start-pair-btn')?.addEventListener('click', () => {
      window.location.href = `/projects/${projectId}/pairs/new`;
    });
  </script>
</AppLayout>
