---
import AppLayout from '../../../../layouts/AppLayout.astro';
const { id } = Astro.params;
---

<AppLayout title="Team" subtitle={`Project ${id}`} currentPath={`/projects/${id}/team`} projectId={id}>
  <div class="max-w-4xl">
    <div id="team-content" class="space-y-6">
      <div class="text-center py-16 text-zinc-500 text-sm">Loading team...</div>
    </div>
  </div>

  <script>
    import { usersApi } from '../../../../api/usersApi';
    import { projectsApi } from '../../../../api/projectsApi';

    const projectId = '{id}';

    async function load() {
      try {
        const [members, roles] = await Promise.all([
          usersApi.teamMembers(projectId),
          usersApi.roleAssignments(projectId),
        ]);

        if (members.length === 0) {
          document.getElementById('team-content')!.innerHTML =
            '<div class="flex flex-col items-center py-16 rounded-xl border border-dashed border-zinc-800"><span class="text-3xl mb-3">👤</span><h3 class="text-sm font-semibold text-zinc-400">No team members</h3><p class="text-xs text-zinc-500 mt-1">Invite members to your project</p></div>';
          return;
        }

        const roleColors: Record<string, string> = {
          Coach: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
          Client: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
          Programmer: 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20',
          Tester: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
          Tracker: 'bg-sky-500/10 text-sky-400 border-sky-500/20',
        };

        document.getElementById('team-content')!.innerHTML = `
          <div class="rounded-xl bg-zinc-900/60 border border-zinc-800 overflow-hidden">
            <div class="px-5 py-4 border-b border-zinc-800/50">
              <h3 class="text-sm font-semibold text-zinc-300">Team Members (${members.length})</h3>
            </div>
            <div class="divide-y divide-zinc-800/50">
              ${members
                .map(
                  (m) => `
                <div class="px-5 py-3.5 flex items-center justify-between hover:bg-zinc-800/20 transition-colors">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-sm font-semibold text-zinc-300">${m.name.charAt(0)}</div>
                    <div>
                      <div class="text-sm font-medium text-zinc-200">${m.name}</div>
                      <div class="text-xs text-zinc-500">${m.email}</div>
                    </div>
                  </div>
                  <span class="text-[10px] font-mono px-2.5 py-0.5 rounded-full border ${roleColors[m.role] || 'bg-zinc-800 text-zinc-400 border-zinc-700'}">${m.role}</span>
                </div>
              `,
                )
                .join('')}
            </div>
          </div>

          <div class="rounded-xl bg-zinc-900/60 border border-zinc-800 p-5">
            <h3 class="text-sm font-semibold text-zinc-300 mb-3">XP Role Distribution</h3>
            <div class="grid grid-cols-5 gap-3 text-center">
              ${['Coach', 'Client', 'Programmer', 'Tester', 'Tracker']
                .map((r) => {
                  const count = roles.filter((m) => m.role === r).length;
                  return `<div class="p-3 rounded-lg bg-zinc-800/30">
                  <div class="text-lg font-bold font-mono text-zinc-100">${count}</div>
                  <div class="text-[10px] text-zinc-500 mt-1">${r}${count !== 1 ? 's' : ''}</div>
                </div>`;
                })
                .join('')}
            </div>
          </div>
        `;
      } catch {
        document.getElementById('team-content')!.innerHTML =
          '<div class="text-center py-16 text-rose-400 text-sm">Failed to load team</div>';
      }
    }
    load();
  </script>
</AppLayout>
