---
import AppLayout from '../../../../layouts/AppLayout.astro';
const { id } = Astro.params;
---

<AppLayout
  title="Retrospectives"
  subtitle={`Project ${id}`}
  currentPath={`/projects/${id}/retrospective`}
  projectId={id}
>
  <div class="max-w-4xl">
    <h2 class="text-sm font-semibold text-zinc-300 mb-6">Iteration Retrospectives</h2>
    <div id="retro-list" class="space-y-3">
      <div class="text-center py-16 text-zinc-500 text-sm">Loading retrospectives...</div>
    </div>
  </div>

  <script>
    import { iterationsApi } from '../../../../api/iterationsApi';
    import { retroApi } from '../../../../api/retroApi';

    const projectId = '{id}';

    (async () => {
      try {
        const its = await iterationsApi.list(projectId);
        const entries = await Promise.all(
          its.map(async (it) => {
            try {
              const retro = await retroApi.listByIteration(projectId, it.id);
              return { iteration: it, entries: retro };
            } catch {
              return { iteration: it, entries: [] };
            }
          }),
        );

        const list = document.getElementById('retro-list')!;
        if (entries.length === 0) {
          list.innerHTML =
            '<div class="flex flex-col items-center py-16 rounded-xl border border-dashed border-zinc-800"><span class="text-3xl mb-3">💬</span><h3 class="text-sm font-semibold text-zinc-400">No retrospectives</h3></div>';
          return;
        }
        list.innerHTML = entries
          .sort((a, b) => b.iteration.number - a.iteration.number)
          .map(
            ({ iteration, entries: retro }) => `
          <a href="/projects/${projectId}/retrospective/${iteration.id}" class="flex items-center justify-between p-4 rounded-xl bg-zinc-900/60 border border-zinc-800 hover:border-zinc-700 transition-all group">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full ${iteration.status === 'Completed' ? 'bg-zinc-600' : 'bg-amber-400'}"></div>
              <div>
                <div class="text-sm font-semibold text-zinc-200">${iteration.name}</div>
                <div class="text-xs text-zinc-500 font-mono mt-0.5">Iter ${iteration.number} · ${retro.length} entries</div>
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-600"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        `,
          )
          .join('');
      } catch {
        document.getElementById('retro-list')!.innerHTML =
          '<div class="text-center py-16 text-rose-400 text-sm">Failed to load</div>';
      }
    })();
  </script>
</AppLayout>
