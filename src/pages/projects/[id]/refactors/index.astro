---
import AppLayout from '../../../../layouts/AppLayout.astro';
const { id } = Astro.params;
---

<AppLayout title="Refactoring Log" subtitle={`Project ${id}`} currentPath={`/projects/${id}/refactors`} projectId={id}>
  <div class="max-w-4xl">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-zinc-300">Refactor & Debt Register</h2>
      <div class="flex items-center gap-3">
        <span id="health-score" class="text-xs font-mono px-2.5 py-1 rounded-full bg-zinc-800 text-zinc-500"
          >-- health score</span
        >
      </div>
    </div>

    <div
      id="refactor-list"
      class="space-y-1 rounded-xl bg-zinc-900/40 border border-zinc-800 divide-y divide-zinc-800/50"
    >
      <div class="px-5 py-8 text-center text-sm text-zinc-500">Loading refactor log...</div>
    </div>
  </div>

  <script>
    import { refactorsApi } from '../../../../api/refactorsApi';

    const projectId = '{id}';

    async function load() {
      try {
        const [items, health] = await Promise.all([
          refactorsApi.list(projectId),
          refactorsApi.healthScore(projectId).catch(() => ({ score: 0 })),
        ]);

        document.getElementById('health-score')!.textContent = `${health.score}% health score`;
        document.getElementById('health-score')!.className =
          `text-xs font-mono px-2.5 py-1 rounded-full ${health.score > 70 ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : health.score > 40 ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' : 'bg-rose-500/10 text-rose-400 border border-rose-500/20'}`;

        if (items.length === 0) {
          document.getElementById('refactor-list')!.innerHTML =
            '<div class="px-5 py-8 text-center text-sm text-zinc-500">🎉 No technical debt recorded</div>';
        } else {
          document.getElementById('refactor-list')!.innerHTML = items
            .map(
              (item) => `
            <div class="px-5 py-3 flex items-center justify-between hover:bg-zinc-800/20 transition-colors">
              <div class="flex items-center gap-3">
                <span class="w-4 h-4 rounded border flex items-center justify-center flex-shrink-0 ${item.status === 'Resolved' ? 'bg-emerald-500/20 border-emerald-500/40' : 'border-zinc-600'}">
                  ${item.status === 'Resolved' ? '<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-emerald-400"><path d="M20 6 9 17l-5-5"/></svg>' : ''}
                </span>
                <div>
                  <span class="text-sm font-medium ${item.status === 'Resolved' ? 'text-zinc-500 line-through' : 'text-zinc-200'}">${item.title}</span>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-[10px] font-mono px-1.5 py-0.5 rounded ${item.type === 'debt' ? 'bg-rose-500/10 text-rose-400' : 'bg-amber-500/10 text-amber-400'}">${item.type}</span>
                    ${item.relatedStory ? `<span class="text-[10px] font-mono text-zinc-600">→ ${item.relatedStory}</span>` : ''}
                  </div>
                </div>
              </div>
              <span class="text-[10px] font-mono text-zinc-600">${new Date(item.date).toLocaleDateString()}</span>
            </div>
          `,
            )
            .join('');
        }
      } catch {
        document.getElementById('refactor-list')!.innerHTML =
          '<div class="px-5 py-8 text-center text-sm text-rose-400">Failed to load refactor log</div>';
      }
    }
    load();
  </script>
</AppLayout>
