---
import AppLayout from '../../../../layouts/AppLayout.astro';
const { id } = Astro.params;
---

<AppLayout title="Iterations" subtitle={`Project ${id}`} currentPath={`/projects/${id}/iterations`} projectId={id}>
  <div class="max-w-4xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-sm font-semibold text-zinc-300">All Iterations</h2>
      <button
        id="new-iteration-btn"
        class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold transition-all cursor-pointer"
      >
        + New Iteration
      </button>
    </div>
    <div id="iteration-list" class="space-y-3">
      <div class="text-center py-16 text-zinc-500 text-sm">Loading iterations...</div>
    </div>
  </div>

  <!-- New Iteration Modal -->
  <div id="iteration-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <div
      class="absolute inset-0 bg-black/60 backdrop-blur-sm"
      onclick="document.getElementById('iteration-modal').classList.add('hidden')"
    >
    </div>
    <div class="relative w-full max-w-lg bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
      <h3 class="text-sm font-semibold text-zinc-200 mb-4">New Iteration</h3>
      <form id="iteration-form" class="space-y-3">
        <input
          id="it-name"
          placeholder="Iteration name"
          class="w-full bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-100"
          required
        />
        <div class="grid grid-cols-2 gap-3">
          <input
            id="it-capacity"
            type="number"
            placeholder="Capacity (pts)"
            class="w-full bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-100"
            required
          />
          <input
            id="it-number"
            type="number"
            placeholder="Iteration number"
            class="w-full bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-100"
            required
          />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <input
            id="it-start"
            type="date"
            class="w-full bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-100"
            required
          />
          <input
            id="it-end"
            type="date"
            class="w-full bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-100"
            required
          />
        </div>
        <div class="flex justify-end gap-2 mt-4">
          <button
            type="button"
            onclick="document.getElementById('iteration-modal').classList.add('hidden')"
            class="px-4 py-2 rounded-lg bg-zinc-800 text-zinc-400 text-xs">Cancel</button
          >
          <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-xs">Create</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { iterationsApi } from '../../../../api/iterationsApi';

    const projectId = '{id}';
    const listEl = document.getElementById('iteration-list');

    async function load() {
      try {
        const its = await iterationsApi.list(projectId);
        if (its.length === 0) {
          listEl.innerHTML = `<div class="flex flex-col items-center py-16 rounded-xl border border-dashed border-zinc-800"><span class="text-3xl mb-3">📅</span><h3 class="text-sm font-semibold text-zinc-400">No iterations</h3><p class="text-xs text-zinc-500 mt-1">Create your first iteration</p></div>`;
          return;
        }
        listEl.innerHTML = its
          .sort((a, b) => b.number - a.number)
          .map(
            (it) => `
          <a href="/projects/${projectId}/iterations/${it.id}" class="flex items-center justify-between p-4 rounded-xl bg-zinc-900/60 border border-zinc-800 hover:border-zinc-700 transition-all group">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full ${it.status === 'Active' ? 'bg-emerald-400 animate-pulse' : it.status === 'Completed' ? 'bg-zinc-600' : 'bg-amber-400'}"></div>
              <div>
                <div class="text-sm font-semibold text-zinc-200">${it.name}</div>
                <div class="text-xs text-zinc-500 font-mono mt-0.5">Iter ${it.number} · ${it.status} · ${it.velocity}/${it.capacity} pts</div>
              </div>
            </div>
            <span class="text-[10px] font-mono px-2 py-0.5 rounded-full ${it.status === 'Active' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-zinc-800 text-zinc-500'}">${it.status}</span>
          </a>
        `,
          )
          .join('');
      } catch {
        listEl.innerHTML = `<div class="text-center py-16 text-rose-400 text-sm">Failed to load iterations</div>`;
      }
    }
    load();

    document.getElementById('new-iteration-btn')?.addEventListener('click', () => {
      document.getElementById('iteration-modal')?.classList.remove('hidden');
    });

    document.getElementById('iteration-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = {
        name: (document.getElementById('it-name') as HTMLInputElement).value,
        capacity: parseInt((document.getElementById('it-capacity') as HTMLInputElement).value),
        number: parseInt((document.getElementById('it-number') as HTMLInputElement).value),
        startDate: (document.getElementById('it-start') as HTMLInputElement).value,
        endDate: (document.getElementById('it-end') as HTMLInputElement).value,
        status: 'Planning',
      };
      try {
        await iterationsApi.create(projectId, data);
        document.getElementById('iteration-modal')?.classList.add('hidden');
        load();
      } catch {}
    });
  </script>
</AppLayout>
