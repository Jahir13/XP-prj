---
import AuthLayout from '../layouts/AuthLayout.astro';
---

<AuthLayout title="Olvidé mi Contraseña">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <h1 class="text-xl font-bold text-zinc-100">Restablecer contraseña</h1>
        <p class="text-sm text-zinc-500 mt-1">
          Ingresa tu correo electrónico para recibir un enlace de restablecimiento
        </p>
      </div>
      <div class="rounded-xl bg-zinc-900/80 border border-zinc-800 p-6">
        <form id="forgot-form" class="space-y-4">
          <div>
            <label for="email" class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-1.5"
              >Correo Electrónico</label
            >
            <input
              type="email"
              id="email"
              required
              placeholder="correo@ejemplo.com"
              autocomplete="email"
              class="w-full bg-zinc-950 border border-zinc-800 focus:border-indigo-500 rounded-lg px-4 py-2.5 text-zinc-100 placeholder-zinc-600 focus:outline-none transition-colors text-sm"
            />
          </div>
          <div
            id="forgot-error"
            role="alert"
            class="hidden text-xs text-rose-400 font-mono bg-rose-500/10 border border-rose-500/20 rounded-lg px-3 py-2"
          >
          </div>
          <div
            id="forgot-success"
            role="status"
            class="hidden text-xs text-emerald-400 font-mono bg-emerald-500/10 border border-emerald-500/20 rounded-lg px-3 py-2"
          >
          </div>
          <button
            type="submit"
            class="w-full py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-sm transition-all cursor-pointer disabled:opacity-50"
          >
            Enviar Enlace
          </button>
        </form>
        <div class="mt-4 text-center">
          <a href="/login" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors"
            >Volver al inicio de sesión</a
          >
        </div>
      </div>
    </div>
  </div>
  <script>
    import { apiPost } from '../api/client';

    const form = document.getElementById('forgot-form') as HTMLFormElement;
    const errorDiv = document.getElementById('forgot-error') as HTMLDivElement;
    const successDiv = document.getElementById('forgot-success') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';

      try {
        await apiPost('/auth/forgot-password', { email });
        successDiv.textContent = 'Si el correo electrónico existe, se ha enviado un enlace de restablecimiento.';
        successDiv.classList.remove('hidden');
        submitBtn.textContent = 'Enviado';
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Ocurrió un error inesperado';
        errorDiv.textContent = message;
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar Enlace';
      }
    });
  </script>
</AuthLayout>
