---
import AppLayout from '../../layouts/AppLayout.astro';
import StoriesList from '../../components/stories/StoriesList';
import { getCollection } from 'astro:content';

const stories = await getCollection('stories');

// Map static stories to the format needed by the React component
const staticStories = stories.map((s) => ({
  id: s.id,
  title: s.data.title,
  businessValue: s.data.businessValue,
  risk: s.data.risk,
  points: s.data.points,
  status: s.data.status,
  iteration: s.data.iteration,
  assignedPair: s.data.assignedPair,
  isTDD: s.data.isTDD,
  acceptanceCriteria: s.data.acceptanceCriteria,
  createdBy: s.data.createdBy,
  estimatedBy: s.data.estimatedBy,
}));
---

<AppLayout title="User Stories" subtitle="The Card File" currentPath="/stories">
  <StoriesList client:load initialStories={staticStories} />
</AppLayout>
